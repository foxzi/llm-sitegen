<?xml version="1.0" encoding="UTF-8"?>
<!-- XML Sitemap Template -->
<!-- Place in root directory: https://example.com/sitemap.xml -->
<!-- Submit to Google Search Console and Bing Webmaster Tools -->

<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9"
        xmlns:image="http://www.google.com/schemas/sitemap-image/1.1"
        xmlns:video="http://www.google.com/schemas/sitemap-video/1.1"
        xmlns:xhtml="http://www.w3.org/1999/xhtml">

  <!-- ============================================ -->
  <!-- BASIC URL ENTRY -->
  <!-- ============================================ -->

  <url>
    <loc>https://example.com/</loc>
    <lastmod>2024-01-15</lastmod>
    <changefreq>daily</changefreq>
    <priority>1.0</priority>
  </url>

  <!-- ============================================ -->
  <!-- STANDARD PAGES -->
  <!-- ============================================ -->

  <url>
    <loc>https://example.com/about</loc>
    <lastmod>2024-01-10</lastmod>
    <changefreq>monthly</changefreq>
    <priority>0.8</priority>
  </url>

  <url>
    <loc>https://example.com/services</loc>
    <lastmod>2024-01-10</lastmod>
    <changefreq>monthly</changefreq>
    <priority>0.8</priority>
  </url>

  <url>
    <loc>https://example.com/pricing</loc>
    <lastmod>2024-01-10</lastmod>
    <changefreq>weekly</changefreq>
    <priority>0.9</priority>
  </url>

  <url>
    <loc>https://example.com/contact</loc>
    <lastmod>2024-01-10</lastmod>
    <changefreq>monthly</changefreq>
    <priority>0.7</priority>
  </url>

  <!-- ============================================ -->
  <!-- BLOG POSTS -->
  <!-- ============================================ -->

  <url>
    <loc>https://example.com/blog</loc>
    <lastmod>2024-01-15</lastmod>
    <changefreq>daily</changefreq>
    <priority>0.8</priority>
  </url>

  <url>
    <loc>https://example.com/blog/post-title</loc>
    <lastmod>2024-01-15</lastmod>
    <changefreq>monthly</changefreq>
    <priority>0.6</priority>
  </url>

  <!-- ============================================ -->
  <!-- PRODUCTS (E-commerce) -->
  <!-- ============================================ -->

  <url>
    <loc>https://example.com/products</loc>
    <lastmod>2024-01-15</lastmod>
    <changefreq>daily</changefreq>
    <priority>0.9</priority>
  </url>

  <url>
    <loc>https://example.com/products/category/electronics</loc>
    <lastmod>2024-01-14</lastmod>
    <changefreq>weekly</changefreq>
    <priority>0.7</priority>
  </url>

  <url>
    <loc>https://example.com/products/product-name</loc>
    <lastmod>2024-01-12</lastmod>
    <changefreq>weekly</changefreq>
    <priority>0.6</priority>
  </url>

  <!-- ============================================ -->
  <!-- WITH IMAGES -->
  <!-- ============================================ -->

  <url>
    <loc>https://example.com/products/product-name</loc>
    <lastmod>2024-01-12</lastmod>
    <image:image>
      <image:loc>https://example.com/images/product-1.jpg</image:loc>
      <image:title>Product Name - Front View</image:title>
      <image:caption>High-quality product image showing front view</image:caption>
    </image:image>
    <image:image>
      <image:loc>https://example.com/images/product-2.jpg</image:loc>
      <image:title>Product Name - Side View</image:title>
    </image:image>
  </url>

  <!-- ============================================ -->
  <!-- WITH VIDEO -->
  <!-- ============================================ -->

  <url>
    <loc>https://example.com/videos/tutorial</loc>
    <video:video>
      <video:thumbnail_loc>https://example.com/thumbnails/video1.jpg</video:thumbnail_loc>
      <video:title>Tutorial Video Title</video:title>
      <video:description>Description of the video content</video:description>
      <video:content_loc>https://example.com/videos/video1.mp4</video:content_loc>
      <video:duration>300</video:duration>
      <video:publication_date>2024-01-10T08:00:00+00:00</video:publication_date>
    </video:video>
  </url>

  <!-- ============================================ -->
  <!-- MULTILINGUAL (hreflang) -->
  <!-- ============================================ -->

  <url>
    <loc>https://example.com/about</loc>
    <xhtml:link rel="alternate" hreflang="en" href="https://example.com/about"/>
    <xhtml:link rel="alternate" hreflang="es" href="https://example.com/es/about"/>
    <xhtml:link rel="alternate" hreflang="fr" href="https://example.com/fr/about"/>
    <xhtml:link rel="alternate" hreflang="x-default" href="https://example.com/about"/>
    <lastmod>2024-01-10</lastmod>
  </url>

</urlset>

